// This Pine Script™ source code is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/

//@version=6
strategy("RSI Channel Strategy (Ladder)", overlay=false, precision=2, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.0, max_bars_back=2000)

// === INPUTS: RSI ===
grpRSI     = "RSI"
rsiLength  = input.int(14, "RSI Length", minval=2, maxval=100, group=grpRSI)
rsiSource  = input.source(close, "RSI Source", group=grpRSI)

// === INPUTS: Channel anchors (define ONE rail of the parallel ladder) ===
grpAnchor      = "Channel Anchors"
point1Time     = input.time(timestamp("2023-04-17T00:00"), "Point 1 Time",  group=grpAnchor, tooltip="Anchor 1 of the base line. Default from user's middle trendline (bar -164, weekly chart).")
point1RSI      = input.float(56.98, "Point 1 RSI", minval=-50.0, maxval=150.0, step=0.01, group=grpAnchor, tooltip="RSI value at anchor 1.")
point2Time     = input.time(timestamp("2030-12-23T00:00"), "Point 2 Time",  group=grpAnchor, tooltip="Anchor 2 of the base line. Default from user's middle trendline (bar 237, weekly chart).")
point2RSI      = input.float(15.53, "Point 2 RSI", minval=-50.0, maxval=150.0, step=0.01, group=grpAnchor, tooltip="RSI value at anchor 2.")
channelWidth   = input.float(37.27, "Ladder Spacing (RSI points)", minval=1.0, step=0.01, group=grpAnchor, tooltip="Vertical distance between adjacent parallel rails. Average of user's 3-line spacing: (37.12 + 37.41) / 2 = 37.27.")
touchTolerance = input.float(1.5,   "Retest Tolerance (RSI points)", minval=0.1, step=0.1,  group=grpAnchor, tooltip="How close RSI must get to the most-recently-broken line to count as a retest.")

// === INPUTS: Backtest range ===
grpRange  = "Backtest Range"
startDate = input.time(timestamp("2021-01-01T00:00"), "Start Date", group=grpRange)
endDate   = input.time(timestamp("2030-01-01T00:00"), "End Date",   group=grpRange)
inRange   = time >= startDate and time <= endDate

// === INPUTS: Strategy rules ===
grpRules            = "Strategy Rules"
enableBreakoutEntry = input.bool(true,  "Long Entry on BUY Breakout (rail crossed up)",  group=grpRules)
enableRetestEntry   = input.bool(true,  "Long Entry on Retest (if flat)",                group=grpRules)
enableInvalidExit   = input.bool(true,  "Exit Long on INVALIDATE (rail crossed down)",   group=grpRules)
enableRetestTP      = input.bool(true,  "Take Profit on Retest (if in profit)",          group=grpRules)
tpMinProfitR        = input.float(0.5,  "Min profit before retest TP fires (price gain × 100 / ladderSpacing)", minval=0.0, step=0.1, group=grpRules, tooltip="Retest TP only fires if open position is up by at least this fraction of a ladder spacing. Prevents flapping on micro-retests.")

// === SYMBOL / TIMEFRAME GUARD (MSTR Daily or Weekly) ===
// Note: timeframe.period returns "1W" on weekly charts, not "W" — use built-in helpers instead.
isMSTR       = syminfo.ticker == "MSTR"
isDaily      = timeframe.isdaily
isWeekly     = timeframe.isweekly
validContext = isMSTR and (isDaily or isWeekly)

// === RSI + BASE LINE ===
rsi      = ta.rsi(rsiSource, rsiLength)
slope    = (point2RSI - point1RSI) / (point2Time - point1Time)
baseLine = point1RSI + slope * (time - point1Time)

// === LADDER TRACKING ===
kAbove    = math.floor((rsi - baseLine) / channelWidth) + 1
upperLine = baseLine + kAbove * channelWidth
lowerLine = baseLine + (kAbove - 1) * channelWidth

// === SIGNALS (gated on MSTR daily or weekly) ===
sameLevel     = kAbove == kAbove[1]
buyBreakout   = validContext and kAbove > kAbove[1]
invalidateBuy = validContext and kAbove < kAbove[1]
retestLine    = validContext and sameLevel and rsi <= lowerLine + touchTolerance and rsi[1] > lowerLine[1] + touchTolerance

// === HELPER: clip a value to visible RSI range so off-chart rails don't stretch the y-axis ===
clipToView(v) => v >= -5.0 and v <= 105.0 ? v : na

// === PLOTS (visual reference during backtest) ===
plot(rsi, "RSI", color=color.new(color.yellow, 0), linewidth=2)

pUpper = plot(clipToView(upperLine), "Active Upper", color=color.new(color.white, 0), linewidth=2)
pLower = plot(clipToView(lowerLine), "Active Lower", color=color.new(color.white, 0), linewidth=2)
fill(pUpper, pLower, color=color.new(color.white, 88), title="Active Channel")

// Ladder rails: only the 3 user-specified reference lines (k = -1, 0, +1). line.new
// endpoints DO affect pane auto-scale, so we limit to 3 rails to keep the y-axis in a
// reasonable range. Ladder math above still tracks all k values for signal generation.
var bool railsCreated = false
if barstate.islast and not railsCreated
    for k = -1 to 1
        y1 = point1RSI + k * channelWidth
        y2 = point2RSI + k * channelWidth
        line.new(point1Time, y1, point2Time, y2, xloc=xloc.bar_time, extend=extend.both, color=color.new(color.red, 20), width=1)
    railsCreated := true

hline(70, "Overbought", color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(50, "Mid",        color=color.new(color.gray, 70), linestyle=hline.style_dotted)
hline(30, "Oversold",   color=color.new(color.gray, 50), linestyle=hline.style_dashed)

// === STRATEGY STATE ===
flat       = strategy.position_size == 0
inLong     = strategy.position_size > 0
entryPrice = strategy.position_avg_price
// Profit measured as fractional price gain compared to a ladder-width-derived threshold.
// Loose scaling (price percent vs RSI points) — adequate as a "don't TP on micro-retest" guard.
inProfit   = inLong and (close - entryPrice) / entryPrice >= tpMinProfitR * (channelWidth / 100.0)

// === STRATEGY ENTRIES (long-only) ===
if inRange and flat and enableBreakoutEntry and buyBreakout
    strategy.entry("Breakout", strategy.long, comment="Breakout")

if inRange and flat and enableRetestEntry and retestLine
    strategy.entry("Retest", strategy.long, comment="RetestEntry")

// === STRATEGY EXITS ===
if inLong and enableInvalidExit and invalidateBuy
    strategy.close_all(comment="Invalidate")

if inLong and enableRetestTP and retestLine and inProfit
    strategy.close_all(comment="RetestTP")

// === SIGNAL MARKERS (plot at RSI value, not at boolean 0/1) ===
plotshape(buyBreakout   ? rsi : na, title="BUY Breakout",   style=shape.triangleup,   location=location.absolute, color=color.new(color.green, 0),  size=size.small, text="BUY")
plotshape(invalidateBuy ? rsi : na, title="INVALIDATE Buy", style=shape.triangledown, location=location.absolute, color=color.new(color.red, 0),    size=size.small, text="INV")
plotshape(retestLine    ? rsi : na, title="RETEST / TP",    style=shape.diamond,      location=location.absolute, color=color.new(color.orange, 0), size=size.small, text="RT")

// === GUARD WARNING LABEL ===
var label warnLabel = na
if barstate.islast
    label.delete(warnLabel)
    if not validContext
        msg = "⚠ Designed for MSTR Daily or Weekly only.\nCurrent: " + syminfo.ticker + " " + timeframe.period
        warnLabel := label.new(bar_index, 50, msg, color=color.red, textcolor=color.white, style=label.style_label_left, size=size.normal)
